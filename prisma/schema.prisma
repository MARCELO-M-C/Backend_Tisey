generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                  BigInt       @id @default(autoincrement()) @db.UnsignedBigInt
  username            String       @unique(map: "username") @db.VarChar(50)
  passwordHash        String       @map("password_hash") @db.VarChar(255)
  firstName           String       @map("first_name") @db.VarChar(80)
  lastName            String       @map("last_name") @db.VarChar(80)
  isActive            Boolean      @default(true) @map("is_active")
  createdAt           DateTime     @default(now()) @map("created_at") @db.DateTime(0)
  printedInvoices     Invoice[]    @relation("InvoicePrintedBy")
  issuedInvoices      Invoice[]    @relation("InvoiceIssuedBy")
  orderEvents         OrderEvent[] @relation("OrderEventPerformedBy")
  deliveredOrderItems OrderItem[]  @relation("OrderItemDeliveredBy")
  preparedOrderItems  OrderItem[]  @relation("OrderItemPreparedBy")
  createdOrders       Order[]      @relation("OrderCreatedBy")
  waiterOrders        Order[]      @relation("OrderWaiter")
  receivedPayments    Payment[]    @relation("PaymentReceivedBy")
  shifts              Shift[]
  createdStays        Stay[]       @relation("StayCreatedBy")
  userRoles           UserRole[]

  @@map("users")
}

model Role {
  id              BigInt           @id @default(autoincrement()) @db.UnsignedBigInt
  name            String           @unique(map: "name") @db.VarChar(50)
  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@map("roles")
}

model Permission {
  id              BigInt           @id @default(autoincrement()) @db.UnsignedBigInt
  code            String           @unique(map: "code") @db.VarChar(80)
  description     String?          @db.VarChar(255)
  rolePermissions RolePermission[]

  @@map("permissions")
}

model UserRole {
  userId BigInt @map("user_id") @db.UnsignedBigInt
  roleId BigInt @map("role_id") @db.UnsignedBigInt
  role   Role   @relation(fields: [roleId], references: [id], onUpdate: Restrict, map: "fk_ur_role")
  user   User   @relation(fields: [userId], references: [id], onUpdate: Restrict, map: "fk_ur_user")

  @@id([userId, roleId])
  @@index([roleId], map: "fk_ur_role")
  @@map("user_roles")
}

model RolePermission {
  roleId       BigInt     @map("role_id") @db.UnsignedBigInt
  permissionId BigInt     @map("permission_id") @db.UnsignedBigInt
  permission   Permission @relation(fields: [permissionId], references: [id], onUpdate: Restrict, map: "fk_rp_perm")
  role         Role       @relation(fields: [roleId], references: [id], onUpdate: Restrict, map: "fk_rp_role")

  @@id([roleId, permissionId])
  @@index([permissionId], map: "fk_rp_perm")
  @@map("role_permissions")
}

model Station {
  id         BigInt      @id @default(autoincrement()) @db.UnsignedBigInt
  code       String      @unique(map: "code") @db.VarChar(30)
  name       String      @db.VarChar(80)
  isActive   Boolean     @default(true) @map("is_active")
  menuItems  MenuItem[]
  orderItems OrderItem[]

  @@map("stations")
}

model MenuCategory {
  id        BigInt     @id @default(autoincrement()) @db.UnsignedBigInt
  name      String     @unique(map: "name") @db.VarChar(80)
  sortOrder Int        @default(0) @map("sort_order")
  isActive  Boolean    @default(true) @map("is_active")
  menuItems MenuItem[]

  @@map("menu_categories")
}

model MenuItem {
  id         BigInt       @id @default(autoincrement()) @db.UnsignedBigInt
  categoryId BigInt       @map("category_id") @db.UnsignedBigInt
  stationId  BigInt       @map("station_id") @db.UnsignedBigInt
  name       String       @unique(map: "uq_menuitem_name") @db.VarChar(120)
  basePrice  Decimal      @map("base_price") @db.Decimal(10, 2)
  isActive   Boolean      @default(true) @map("is_active")
  createdAt  DateTime     @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt  DateTime?    @map("updated_at") @db.DateTime(0)
  category   MenuCategory @relation(fields: [categoryId], references: [id], onUpdate: Restrict, map: "fk_mi_cat")
  station    Station      @relation(fields: [stationId], references: [id], onUpdate: Restrict, map: "fk_mi_station")
  orderItems OrderItem[]

  @@index([categoryId], map: "idx_menuitems_category")
  @@index([stationId], map: "idx_menuitems_station")
  @@map("menu_items")
}

model RestaurantTable {
  id       BigInt  @id @default(autoincrement()) @db.UnsignedBigInt
  code     String  @unique(map: "code") @db.VarChar(20)
  name     String? @db.VarChar(50)
  capacity Int?
  isActive Boolean @default(true) @map("is_active")
  orders   Order[]

  @@map("restaurant_tables")
}

model Shift {
  id        BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  userId    BigInt    @map("user_id") @db.UnsignedBigInt
  startedAt DateTime  @default(now()) @map("started_at") @db.DateTime(0)
  endedAt   DateTime? @map("ended_at") @db.DateTime(0)
  notes     String?   @db.VarChar(255)
  orders    Order[]
  user      User      @relation(fields: [userId], references: [id], onUpdate: Restrict, map: "fk_shift_user")

  @@index([userId, startedAt], map: "idx_shifts_user_started")
  @@map("shifts")
}

model Cabin {
  id                BigInt        @id @default(autoincrement()) @db.UnsignedBigInt
  cabinNumber       Int           @unique(map: "cabin_number") @map("cabin_number")
  name              String?       @db.VarChar(80)
  capacity          Int
  basePricePerNight Decimal?      @map("base_price_per_night") @db.Decimal(10, 2)
  status            cabins_status @default(AVAILABLE)
  isActive          Boolean       @default(true) @map("is_active")
  stays             Stay[]

  @@map("cabins")
}

model Guest {
  id           BigInt      @id @default(autoincrement()) @db.UnsignedBigInt
  fullName     String      @map("full_name") @db.VarChar(160)
  idNumber     String?     @map("id_number") @db.VarChar(40)
  originPlace  String?     @map("origin_place") @db.VarChar(120)
  createdAt    DateTime    @default(now()) @map("created_at") @db.DateTime(0)
  stayGuests   StayGuest[]
  primaryStays Stay[]      @relation("StayPrimaryGuest")

  @@index([fullName], map: "idx_guest_name")
  @@index([idNumber], map: "idx_guest_idnum")
  @@map("guests")
}

model Stay {
  id             BigInt      @id @default(autoincrement()) @db.UnsignedBigInt
  cabinId        BigInt      @map("cabin_id") @db.UnsignedBigInt
  primaryGuestId BigInt      @map("primary_guest_id") @db.UnsignedBigInt
  checkInDate    DateTime    @map("check_in_date") @db.Date
  checkOutDate   DateTime    @map("check_out_date") @db.Date
  status         StayStatus  @default(CHECKED_IN)
  createdBy      BigInt?     @map("created_by") @db.UnsignedBigInt
  createdAt      DateTime    @default(now()) @map("created_at") @db.DateTime(0)
  invoices       Invoice[]
  orders         Order[]
  stayGuests     StayGuest[]
  cabin          Cabin       @relation(fields: [cabinId], references: [id], onUpdate: Restrict, map: "fk_stay_cabin")
  createdByUser  User?       @relation("StayCreatedBy", fields: [createdBy], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "fk_stay_createdby")
  primaryGuest   Guest       @relation("StayPrimaryGuest", fields: [primaryGuestId], references: [id], onUpdate: Restrict, map: "fk_stay_guest")

  @@index([checkInDate, checkOutDate], map: "idx_stays_dates")
  @@index([cabinId], map: "idx_stays_cabin")
  @@index([createdBy], map: "fk_stay_createdby")
  @@index([primaryGuestId], map: "fk_stay_guest")
  @@map("stays")
}

model StayGuest {
  stayId  BigInt @map("stay_id") @db.UnsignedBigInt
  guestId BigInt @map("guest_id") @db.UnsignedBigInt
  guest   Guest  @relation(fields: [guestId], references: [id], onUpdate: Restrict, map: "fk_sg_guest")
  stay    Stay   @relation(fields: [stayId], references: [id], onUpdate: Restrict, map: "fk_sg_stay")

  @@id([stayId, guestId])
  @@index([guestId], map: "fk_sg_guest")
  @@map("stay_guests")
}

model Order {
  id            BigInt           @id @default(autoincrement()) @db.UnsignedBigInt
  orderCode     String           @unique(map: "order_code") @map("order_code") @db.VarChar(30)
  channel       OrderChannel
  serviceMode   ServiceMode      @map("service_mode")
  status        OrderStatus      @default(DRAFT)
  tableId       BigInt?          @map("table_id") @db.UnsignedBigInt
  stayId        BigInt?          @map("stay_id") @db.UnsignedBigInt
  createdBy     BigInt           @map("created_by") @db.UnsignedBigInt
  waiterId      BigInt?          @map("waiter_id") @db.UnsignedBigInt
  shiftId       BigInt?          @map("shift_id") @db.UnsignedBigInt
  notes         String?          @db.VarChar(500)
  createdAt     DateTime         @default(now()) @map("created_at") @db.DateTime(0)
  sentAt        DateTime?        @map("sent_at") @db.DateTime(0)
  closedAt      DateTime?        @map("closed_at") @db.DateTime(0)
  cancelledAt   DateTime?        @map("cancelled_at") @db.DateTime(0)
  cancelReason  String?          @map("cancel_reason") @db.VarChar(255)
  invoices      Invoice[]
  events        OrderEvent[]
  items         OrderItem[]
  createdByUser User             @relation("OrderCreatedBy", fields: [createdBy], references: [id], onUpdate: Restrict, map: "fk_order_createdby")
  shift         Shift?           @relation(fields: [shiftId], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "fk_order_shift")
  stay          Stay?            @relation(fields: [stayId], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "fk_order_stay")
  table         RestaurantTable? @relation(fields: [tableId], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "fk_order_table")
  waiter        User?            @relation("OrderWaiter", fields: [waiterId], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "fk_order_waiter")

  @@index([status, createdAt], map: "idx_orders_status_created")
  @@index([waiterId, createdAt], map: "idx_orders_waiter_created")
  @@index([createdBy], map: "fk_order_createdby")
  @@index([shiftId], map: "fk_order_shift")
  @@index([stayId], map: "fk_order_stay")
  @@index([tableId], map: "fk_order_table")
  @@map("orders")
}

model OrderItem {
  id              BigInt          @id @default(autoincrement()) @db.UnsignedBigInt
  orderId         BigInt          @map("order_id") @db.UnsignedBigInt
  menuItemId      BigInt?         @map("menu_item_id") @db.UnsignedBigInt
  itemName        String          @map("item_name") @db.VarChar(120)
  stationId       BigInt          @map("station_id") @db.UnsignedBigInt
  unitPrice       Decimal         @map("unit_price") @db.Decimal(10, 2)
  quantity        Int             @default(1)
  itemNotes       String?         @map("item_notes") @db.VarChar(255)
  itemStatus      OrderItemStatus @default(PENDING) @map("item_status")
  createdAt       DateTime        @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt       DateTime?       @map("updated_at") @db.DateTime(0)
  startedAt       DateTime?       @map("started_at") @db.DateTime(0)
  readyAt         DateTime?       @map("ready_at") @db.DateTime(0)
  deliveredAt     DateTime?       @map("delivered_at") @db.DateTime(0)
  preparedBy      BigInt?         @map("prepared_by") @db.UnsignedBigInt
  deliveredBy     BigInt?         @map("delivered_by") @db.UnsignedBigInt
  invoiceLines    InvoiceLine[]
  deliveredByUser User?           @relation("OrderItemDeliveredBy", fields: [deliveredBy], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "fk_oi_delivered_by")
  menuItem        MenuItem?       @relation(fields: [menuItemId], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "fk_oi_menuitem")
  order           Order           @relation(fields: [orderId], references: [id], onUpdate: Restrict, map: "fk_oi_order")
  preparedByUser  User?           @relation("OrderItemPreparedBy", fields: [preparedBy], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "fk_oi_prepared_by")
  station         Station         @relation(fields: [stationId], references: [id], onUpdate: Restrict, map: "fk_oi_station")

  @@index([orderId], map: "idx_items_order")
  @@index([stationId, itemStatus, createdAt], map: "idx_items_station_status")
  @@index([deliveredBy], map: "fk_oi_delivered_by")
  @@index([menuItemId], map: "fk_oi_menuitem")
  @@index([preparedBy], map: "fk_oi_prepared_by")
  @@map("order_items")
}

model OrderEvent {
  id              BigInt         @id @default(autoincrement()) @db.UnsignedBigInt
  orderId         BigInt         @map("order_id") @db.UnsignedBigInt
  eventType       OrderEventType @map("event_type")
  oldValue        String?        @map("old_value") @db.VarChar(200)
  newValue        String?        @map("new_value") @db.VarChar(200)
  performedBy     BigInt         @map("performed_by") @db.UnsignedBigInt
  performedAt     DateTime       @default(now()) @map("performed_at") @db.DateTime(0)
  order           Order          @relation(fields: [orderId], references: [id], onUpdate: Restrict, map: "fk_oe_order")
  performedByUser User           @relation("OrderEventPerformedBy", fields: [performedBy], references: [id], onUpdate: Restrict, map: "fk_oe_user")

  @@index([orderId, performedAt], map: "idx_events_order_time")
  @@index([performedBy], map: "fk_oe_user")
  @@map("order_events")
}

model Invoice {
  id            BigInt        @id @default(autoincrement()) @db.UnsignedBigInt
  invoiceCode   String        @unique(map: "invoice_code") @map("invoice_code") @db.VarChar(30)
  status        InvoiceStatus @default(ISSUED)
  issuedBy      BigInt        @map("issued_by") @db.UnsignedBigInt
  issuedAt      DateTime      @default(now()) @map("issued_at") @db.DateTime(0)
  orderId       BigInt?       @map("order_id") @db.UnsignedBigInt
  stayId        BigInt?       @map("stay_id") @db.UnsignedBigInt
  subtotal      Decimal       @default(0.00) @db.Decimal(10, 2)
  tax           Decimal       @default(0.00) @db.Decimal(10, 2)
  total         Decimal       @default(0.00) @db.Decimal(10, 2)
  notes         String?       @db.VarChar(255)
  printedAt     DateTime?     @map("printed_at") @db.DateTime(0)
  printedBy     BigInt?       @map("printed_by") @db.UnsignedBigInt
  printCount    Int           @default(0) @map("print_count")
  lines         InvoiceLine[]
  order         Order?        @relation(fields: [orderId], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "fk_inv_order")
  printedByUser User?         @relation("InvoicePrintedBy", fields: [printedBy], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "fk_inv_printed_by")
  stay          Stay?         @relation(fields: [stayId], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "fk_inv_stay")
  issuedByUser  User          @relation("InvoiceIssuedBy", fields: [issuedBy], references: [id], onUpdate: Restrict, map: "fk_inv_user")
  payments      Payment[]

  @@index([issuedAt], map: "idx_invoice_time")
  @@index([orderId], map: "idx_invoice_order")
  @@index([stayId], map: "idx_invoice_stay")
  @@index([printedBy], map: "fk_inv_printed_by")
  @@index([issuedBy], map: "fk_inv_user")
  @@map("invoices")
}

model InvoiceLine {
  id          BigInt            @id @default(autoincrement()) @db.UnsignedBigInt
  invoiceId   BigInt            @map("invoice_id") @db.UnsignedBigInt
  source      InvoiceLineSource
  description String            @db.VarChar(160)
  quantity    Int               @default(1)
  unitPrice   Decimal           @map("unit_price") @db.Decimal(10, 2)
  lineTotal   Decimal           @map("line_total") @db.Decimal(10, 2)
  orderItemId BigInt?           @map("order_item_id") @db.UnsignedBigInt
  createdAt   DateTime          @default(now()) @map("created_at") @db.DateTime(0)
  invoice     Invoice           @relation(fields: [invoiceId], references: [id], onUpdate: Restrict, map: "fk_il_invoice")
  orderItem   OrderItem?        @relation(fields: [orderItemId], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "fk_il_orderitem")

  @@index([invoiceId], map: "idx_invlines_invoice")
  @@index([orderItemId], map: "fk_il_orderitem")
  @@map("invoice_lines")
}

model Payment {
  id             BigInt        @id @default(autoincrement()) @db.UnsignedBigInt
  invoiceId      BigInt        @map("invoice_id") @db.UnsignedBigInt
  method         PaymentMethod
  amount         Decimal       @db.Decimal(10, 2)
  reference      String?       @db.VarChar(80)
  paidAt         DateTime      @default(now()) @map("paid_at") @db.DateTime(0)
  receivedBy     BigInt        @map("received_by") @db.UnsignedBigInt
  invoice        Invoice       @relation(fields: [invoiceId], references: [id], onUpdate: Restrict, map: "fk_pay_invoice")
  receivedByUser User          @relation("PaymentReceivedBy", fields: [receivedBy], references: [id], onUpdate: Restrict, map: "fk_pay_user")

  @@index([invoiceId], map: "idx_pay_invoice")
  @@index([paidAt], map: "idx_pay_time")
  @@index([receivedBy], map: "fk_pay_user")
  @@map("payments")
}

enum StayStatus {
  BOOKED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
}

enum OrderChannel {
  DINE_IN
  TAKE_AWAY
  ROOM_CHARGE
}

enum ServiceMode {
  EAT_HERE
  TO_GO
}

enum OrderStatus {
  DRAFT
  SENT
  IN_PROGRESS
  READY
  DELIVERED
  CLOSED
  CANCELLED
}

enum OrderItemStatus {
  PENDING
  IN_PROGRESS
  READY
  DELIVERED
  CANCELLED
}

enum OrderEventType {
  STATUS_CHANGE
  ITEM_ADDED
  ITEM_UPDATED
  ITEM_CANCELLED
  NOTE_UPDATED
  OTHER
}

enum InvoiceStatus {
  ISSUED
  VOID
}

enum InvoiceLineSource {
  RESTAURANT
  ROOM
  EXTRA
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  MIXED
  OTHER
}

enum cabins_status {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
}
